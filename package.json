{
  "name": "meme-enhancer-9000",
  "version": "0.0.1",
  "description": "Meme Enhancer 9000 – Private browser editor. Upload Image/Video/GIF, add text/image layers, move them, and save as Image or GIF.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 9000",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 9000",
    "start": "node server.js",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "tauri": "tauri",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build"
  },
  "dependencies": {
    "@ffmpeg/core": "0.12.10",
    "@ffmpeg/ffmpeg": "0.12.15",
    "@tauri-apps/api": "2.11.1",
    "@tauri-apps/plugin-dialog": "2.7.1",
    "@tauri-apps/plugin-fs": "2.5.1"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tauri-apps/cli": "2.11.3",
    "@tsconfig/svelte": "5.0.8",
    "svelte": "5.56.3",
    "svelte-check": "4.6.0",
    "typescript": "6.0.3",
    "vite": "8.0.16"
  }
}
